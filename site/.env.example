# Free UX teardown form delivery (app/api/teardown).
# Set ONE of the two delivery methods, plus where it should go. Copy to .env.local and fill in.

# ── Option A: email via Resend (recommended) ────────────────────────────────
# Sign up at resend.com, verify a sending domain, paste the API key.
RESEND_API_KEY=
# The verified sender address (must belong to your Resend-verified domain):
TEARDOWN_FROM=teardown@ledenov.com
# Where teardown requests land (defaults to yevledenov@gmail.com if unset):
TEARDOWN_TO=yevledenov@gmail.com

# ── Option B: webhook instead of email (Slack / Zapier / Make / Discord) ─────
# Used only when RESEND_API_KEY is NOT set (email takes priority if both are present).
TEARDOWN_WEBHOOK_URL=

# With neither set, the route logs the lead to the server console and the form
# still confirms to the user (and falls back to a mailto client-side on failure).
